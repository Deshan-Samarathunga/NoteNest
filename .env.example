# You log in to NoteNest with your real mega.nz email + password.
# No MEGA account or app username is configured here anymore.

# Notes are stored in this folder inside each user's own MEGA Drive.
MEGA_FOLDER_NAME=NoteNest

# Used to sign session tokens AND to encrypt the MEGA credentials carried inside
# them. Keep it secret and long/random. Anyone with this value can decrypt tokens.
SESSION_SECRET=replace-with-a-long-random-secret

ENABLE_ENCRYPTION=false
PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
